# ================================================
# VARIABLES D'ENVIRONNEMENT — AURORE MICHAUD SITE
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS PARTAGER OU PUBLIER LE FICHIER .env.local
# ================================================

# Email (Gmail) — pour recevoir les notifications de commandes
# Utiliser un "mot de passe d'application" Gmail (pas ton vrai mot de passe)
# Activer sur : myaccount.google.com > Sécurité > Mots de passe des applications
EMAIL_USER=ton.email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Mot de passe admin (pour accéder à /admin)
NEXT_PUBLIC_ADMIN_PWD=tonMotDePasseAdmin2026

# URL du site (pour les liens dans les emails)
NEXT_PUBLIC_URL=https://www.auroremichaud.fr
